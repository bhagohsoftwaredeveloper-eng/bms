{
  "expo": {
    "name": "Beulah Field",
    "slug": "orbit-console",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "beulah",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#4f46e5"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.beulah.field"
    },
    "android": {
      "package": "com.beulah.field",
      "adaptiveIcon": {
        "backgroundColor": "#4f46e5"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Beulah Field to capture the installation location for proof of service."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Beulah Field to attach installation photos as proof of service."
        }
      ]
    ],
    "extra": {
      "apiUrl": "https://0rex-server.tail7dcc9b.ts.net/api",
      "router": {},
      "eas": {
        "projectId": "15bee5ca-b863-412c-8d96-51688866934e"
      }
    },
    "owner": "rexposdevs-organization"
  }
}
